# Copy this file to .env and fill values

# ===== AI BRAIN =====
# Get Gemini Key: https://makersuite.google.com/app/apikey (60 req/min FREE)
GEMINI_API_KEY=

# Get Groq Key: https://console.groq.com/keys (14,400 req/day FREE)
# Groq is recommended as fallback - fast and free!
GROQ_API_KEY=

# Use local LLM instead of cloud (requires Ollama running)
USE_LOCAL_LLM=false
LOCAL_LLM_URL=http://localhost:11434/api/generate
LOCAL_LLM_MODEL=llama3

# ===== FEATURES =====
# Get World News API Key: https://worldnewsapi.com/ (1000 req/day FREE)
# This key goes in NEWS_API_KEY
NEWS_API_KEY=

# Get WolframAlpha Key: https://developer.wolframalpha.com/portal/myapps/
WOLFRAM_ALPHA_API_KEY=

# HuggingFace Chat (deprecated - use Gemini/Groq instead)
HUGCHAT_COOKIE_PATH=cookies.json
